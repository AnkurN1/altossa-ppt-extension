{
  "manifest_version": 3,
  "name": "Altossa PPT Extension",
  "version": "1.0",
  "permissions": [
    "storage",
    "downloads",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://https://altossa-ppt-extension.onrender.com/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}

